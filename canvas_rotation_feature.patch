+/* -------------------------------------------------------------------- */
+/** \name View Rotate Operator (modal drag)
+ * \{ */
+
+struct v2dViewRotateData {
+  bScreen *screen;
+  ScrArea *area;
+  ARegion *region;
+  View2D *v2d;
+
+  float start_angle;
+  float original_rotation;
+  bool own_cursor;
+};
+
+static float get_mouse_angle(ARegion *region, const int xy[2])
+{
+  const float cx = float(region->winx) / 2.0f;
+  const float cy = float(region->winy) / 2.0f;
+  return atan2f(float(xy[1]) - cy, float(xy[0]) - cx);
+}
+
+static void view_rotate_apply(bContext *C, v2dViewRotateData *vrd, float delta_angle)
+{
+  vrd->v2d->rotation = vrd->original_rotation + delta_angle;
+
+  /* clamp to -pi .. pi just to avoid huge floats over time */
+  while (vrd->v2d->rotation > float(M_PI)) {
+    vrd->v2d->rotation -= 2.0f * float(M_PI);
+  }
+  while (vrd->v2d->rotation < float(-M_PI)) {
+    vrd->v2d->rotation += 2.0f * float(M_PI);
+  }
+
+  view2d_curRect_changed(C, vrd->v2d);
+  ED_region_tag_redraw_no_rebuild(vrd->region);
+  WM_event_add_mousemove(CTX_wm_window(C));
+  view2d_sync(vrd->screen, vrd->area, vrd->v2d, V2D_LOCK_COPY);
+}
+
+static wmOperatorStatus view_rotate_invoke(bContext *C, wmOperator *op, const wmEvent *event)
+{
+  if (!view_pan_poll(C)) {
+    return OPERATOR_CANCELLED;
+  }
+
+  v2dViewRotateData *vrd = MEM_new_zeroed<v2dViewRotateData>(__func__);
+  op->customdata = vrd;
+
+  vrd->screen = CTX_wm_screen(C);
+  vrd->area = CTX_wm_area(C);
+  vrd->region = CTX_wm_region(C);
+  vrd->v2d = &vrd->region->v2d;
+  vrd->original_rotation = vrd->v2d->rotation;
+
+  vrd->start_angle = get_mouse_angle(vrd->region, event->xy);
+  vrd->v2d->flag |= V2D_IS_NAVIGATING;
+
+  wmWindow *window = CTX_wm_window(C);
+  if (WM_cursor_modal_is_set_ok(window)) {
+    WM_cursor_modal_set(window, WM_CURSOR_EW_SCROLL);
+    vrd->own_cursor = true;
+  }
+
+  WM_event_add_modal_handler(C, op);
+  return OPERATOR_RUNNING_MODAL;
+}
+
+static wmOperatorStatus view_rotate_modal(bContext *C, wmOperator *op, const wmEvent *event)
+{
+  v2dViewRotateData *vrd = static_cast<v2dViewRotateData *>(op->customdata);
+
+  if (event->type == MOUSEMOVE) {
+    const float angle = get_mouse_angle(vrd->region, event->xy);
+    float delta = angle - vrd->start_angle;
+    
+    /* handle wrap around */
+    if (delta > float(M_PI)) {
+      delta -= 2.0f * float(M_PI);
+    }
+    else if (delta < float(-M_PI)) {
+      delta += 2.0f * float(M_PI);
+    }
+
+    view_rotate_apply(C, vrd, delta);
+  }
+  else if (ELEM(event->type, LEFTMOUSE, MIDDLEMOUSE, RIGHTMOUSE, EVT_ESCKEY)) {
+    if (event->val == KM_RELEASE || event->type == EVT_ESCKEY) {
+      if (event->type == EVT_ESCKEY) {
+        view_rotate_apply(C, vrd, 0.0f); /* reset */
+      }
+      vrd->v2d->flag &= ~V2D_IS_NAVIGATING;
+      if (vrd->own_cursor) {
+        WM_cursor_modal_restore(CTX_wm_window(C));
+      }
+      MEM_delete(vrd);
+      op->customdata = nullptr;
+      return (event->type == EVT_ESCKEY) ? OPERATOR_CANCELLED : OPERATOR_FINISHED;
+    }
+  }
+
+  return OPERATOR_RUNNING_MODAL;
+}
+
+static void view_rotate_cancel(bContext *C, wmOperator *op)
+{
+  v2dViewRotateData *vrd = static_cast<v2dViewRotateData *>(op->customdata);
+  if (vrd) {
+    view_rotate_apply(C, vrd, 0.0f);
+    vrd->v2d->flag &= ~V2D_IS_NAVIGATING;
+    if (vrd->own_cursor) {
+      WM_cursor_modal_restore(CTX_wm_window(C));
+    }
+    MEM_delete(vrd);
+    op->customdata = nullptr;
+  }
+}
+
+static void VIEW2D_OT_rotate(wmOperatorType *ot)
+{
+  ot->name = "Rotate View";
+  ot->description = "Rotate the view";
+  ot->idname = "VIEW2D_OT_rotate";
+
+  ot->invoke = view_rotate_invoke;
+  ot->modal = view_rotate_modal;
+  ot->cancel = view_rotate_cancel;
+  ot->poll = view_pan_poll; /* We can use pan poll because if you can pan you can rotate typically */
+
+  ot->flag = OPTYPE_BLOCKING | OPTYPE_GRAB_CURSOR_XY;
+}
