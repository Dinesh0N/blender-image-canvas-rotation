diff --git a/source/blender/editors/space_image/space_image.cc b/source/blender/editors/space_image/space_image.cc
index 5d3470ac0df..d10c45d72b3 100644
--- a/source/blender/editors/space_image/space_image.cc
+++ b/source/blender/editors/space_image/space_image.cc
@@ -697,6 +697,52 @@ static void image_main_region_set_view2d(SpaceImage *sima, ARegion *region)
   region->v2d.cur.xmax /= w;
   region->v2d.cur.ymin /= h;
   region->v2d.cur.ymax /= h;
+
+  /* Enable custom rotation pivot for 2D rotation. */
+  region->v2d.flag |= V2D_CUSTOM_ROTATION_PIVOT;
+
+  float new_px = 0.5f;
+  float new_py = 0.5f;
+
+  if (ima && ima->source == IMA_SRC_TILED) {
+    ImageTile *active_tile = (ImageTile *)BLI_findlink(&ima->tiles, ima->active_tile_index);
+    if (active_tile) {
+      int tile_idx = active_tile->tile_number - 1001;
+      if (tile_idx >= 0) {
+        new_px = 0.5f + float(tile_idx % 10);
+        new_py = 0.5f + float(tile_idx / 10);
+      }
+    }
+  }
+
+  /* If the pivot changed during an active rotation, mathematically counteract the jump 
+   * by translating the base panning offsets so the visual position is locked. */
+  if (region->v2d.rotation_pivot[0] != new_px || region->v2d.rotation_pivot[1] != new_py) {
+    if (region->v2d.rotation != 0.0f) {
+      float aspect = blender::ui::UI_view2d_rotation_aspect(&region->v2d);
+      
+      float dx = new_px - region->v2d.rotation_pivot[0];
+      float dy = new_py - region->v2d.rotation_pivot[1];
+      
+      float c = cosf(-region->v2d.rotation);
+      float s = sinf(-region->v2d.rotation);
+      
+      float delta_x = dx - (c * dx - s * dy * aspect);
+      float delta_y = dy - ((s / aspect) * dx + c * dy);
+      
+      /* sima->xof contributes `sima->xof / w` to `v2d->cur.xmin`, multiply by `w` to un-normalize. */
+      sima->xof += delta_x * w;
+      sima->yof += delta_y * h;
+      
+      /* Also instantly apply this offset to the un-normalized `v2d->cur` for this frame */
+      region->v2d.cur.xmin += delta_x;
+      region->v2d.cur.xmax += delta_x;
+      region->v2d.cur.ymin += delta_y;
+      region->v2d.cur.ymax += delta_y;
+    }
+    region->v2d.rotation_pivot[0] = new_px;
+    region->v2d.rotation_pivot[1] = new_py;
+  }
 }
 
