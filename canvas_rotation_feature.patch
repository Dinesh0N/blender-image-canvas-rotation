+/* -------------------------------------------------------------------- */
+/** \name Rotation Helpers
+ *
+ * Shared helpers for applying 2D canvas rotation in coordinate transforms.
+ * \{ */
+
+float UI_view2d_rotation_aspect(const View2D *v2d)
+{
+  const float cur_width = BLI_rctf_size_x(&v2d->cur);
+  const float cur_height = BLI_rctf_size_y(&v2d->cur);
+  const float mask_width = float(BLI_rcti_size_x(&v2d->mask));
+  const float mask_height = float(BLI_rcti_size_y(&v2d->mask));
+
+  if (cur_width != 0.0f && cur_height != 0.0f && mask_width != 0.0f) {
+    return (mask_height / cur_height) / (mask_width / cur_width);
+  }
+  return 1.0f;
+}
+
+/**
+ * Compute the rotation pivot and aspect ratio for a View2D.
+ * Used by all rotation transform functions to avoid duplicating this logic.
+ */
+static void view2d_rotation_params(const View2D *v2d,
+                                   float *r_cx,
+                                   float *r_cy,
+                                   float *r_aspect)
+{
+  *r_aspect = UI_view2d_rotation_aspect(v2d);
+  if (v2d->flag & V2D_CUSTOM_ROTATION_PIVOT) {
+    *r_cx = v2d->rotation_pivot[0];
+    *r_cy = v2d->rotation_pivot[1];
+  }
+  else {
+    *r_cx = BLI_rctf_cent_x(&v2d->cur);
+    *r_cy = BLI_rctf_cent_y(&v2d->cur);
+  }
+}
+
+/**
+ * Apply the GPU rotation matrix for View2D canvas rotation.
+ * Used by view2d_view_ortho and view2d_view_orthoSpecial.
+ */
+static void view2d_apply_rotation_matrix(const View2D *v2d)
+{
+  float cx, cy, aspect;
+  view2d_rotation_params(v2d, &cx, &cy, &aspect);
+
+  GPU_matrix_translate_2f(cx, cy);
+  GPU_matrix_scale_2f(1.0f, 1.0f / aspect);
+  GPU_matrix_rotate_2d(RAD2DEGF(-v2d->rotation));
+  GPU_matrix_scale_2f(1.0f, aspect);
+  GPU_matrix_translate_2f(-cx, -cy);
+}
+
+/**
+ * Rotate a point from view-space to rotated-view-space (forward rotation).
+ * Used by view2d_region_to_view.
+ */
+static void view2d_rotate_point_forward(
+    const View2D *v2d, float *r_x, float *r_y)
+{
+  float cx, cy, aspect;
+  view2d_rotation_params(v2d, &cx, &cy, &aspect);
+
+  const float dx = *r_x - cx;
+  const float dy = (*r_y - cy) * aspect;
+  const float cos_r = cosf(v2d->rotation);
+  const float sin_r = sinf(v2d->rotation);
+  *r_x = cx + dx * cos_r - dy * sin_r;
+  *r_y = cy + (dx * sin_r + dy * cos_r) / aspect;
+}
+
+/**
+ * Rotate a point from rotated-view-space back to view-space (inverse rotation).
+ * Used by view2d_view_to_region_clip, view2d_view_to_region, view2d_view_to_region_fl.
+ */
+static void view2d_rotate_point_inverse(
+    const View2D *v2d, float *r_x, float *r_y)
+{
+  float cx, cy, aspect;
+  view2d_rotation_params(v2d, &cx, &cy, &aspect);
+
+  const float dx = *r_x - cx;
+  const float dy = (*r_y - cy) * aspect;
+  const float cos_r = cosf(-v2d->rotation);
+  const float sin_r = sinf(-v2d->rotation);
+  *r_x = cx + dx * cos_r - dy * sin_r;
+  *r_y = cy + (dx * sin_r + dy * cos_r) / aspect;
+}
